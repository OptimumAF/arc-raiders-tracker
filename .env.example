# ArcTracker app key (required for authenticated endpoints)
ARC_APP_KEY=arc_k1_your_app_key

# ArcTracker user key (optional: can also be pasted in app UI)
ARC_USER_KEY=arc_u1_your_user_key

# Backward-compatible aliases supported by the app
# key=arc_k1_your_app_key
# user_key=arc_u1_your_user_key

# Optional local data repo override
# ARC_DATA_REPO_DIR=C:\path\to\arcraiders-data

# Optional cache directory override
# ARC_CACHE_DIR=cache

# Optional request pacing/retries
# ARC_API_MIN_INTERVAL_MS=1000
# ARC_API_MAX_RETRIES=2
# ARC_API_RETRY_BASE_MS=1500
# ARC_API_RETRY_MAX_MS=10000

# Logging
# RUST_LOG=info
